{
	"name": "pumpkin-tree-monorepo",
	"private": true,
	"packageManager": "bun@1.3.11",
	"workspaces": [
		"apps/*",
		"packages/*"
	],
	"scripts": {
		"dev": "bun --filter \"*\" dev",
		"build": "bun --filter \"*\" build",
		"test": "bun --filter \"*\" test",
		"lint": "bun --filter \"*\" lint",
		"format": "bun --filter \"*\" format",
		"lint:deps": "bun install --frozen-lockfile --dry-run",
		"typecheck:graph": "bunx tsc -b tsconfig.json"
	},
	"devDependencies": {
		"@biomejs/biome": "2.2.5",
		"@types/node": "^25.0.9",
		"lefthook": "^2.0.15",
		"typescript": "^5.9.3",
		"wrangler": "4.59.2"
	}
}
