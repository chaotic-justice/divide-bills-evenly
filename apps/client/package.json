{
	"name": "pumpkin-tree-client",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"dev": "bunx vite",
		"build": "bunx tsc -b && bunx vite build",
		"preview": "bun run build && bunx vite preview",
		"cf-typegen": "bunx wrangler types",
		"deploy": "bun run build && bunx wrangler deploy",
		"deploy:production": "bun run build && bunx wrangler deploy --env=production",
		"deploy:staging": "bun run build && bunx wrangler deploy --env=staging",
		"test": "bunx vitest",
		"test:ui": "bunx vitest --ui",
		"test:watch": "bunx vitest --watch",
		"test:coverage": "bunx vitest --coverage",
		"lint": "bunx biome lint .",
		"format": "bunx biome format --write .",
		"format:check": "bunx biome format .",
		"lint:fix": "bunx biome lint --fix .",
		"check": "bunx biome check .",
		"check:fix": "bunx biome check --fix ."
	},
	"dependencies": {
		"@cloudflare/vite-plugin": "^1.17.1",
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-checkbox": "^1.3.3",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-radio-group": "^1.3.8",
		"@radix-ui/react-select": "^2.2.6",
		"@radix-ui/react-slot": "^1.2.4",
		"@tailwindcss/vite": "^4.1.18",
		"@tanstack/react-query": "^5.90.12",
		"@tanstack/react-query-devtools": "^5.91.1",
		"@tanstack/react-router": "^1.141.2",
		"@tanstack/react-router-devtools": "^1.141.2",
		"@tanstack/react-router-ssr-query": "^1.141.2",
		"@tanstack/react-start": "^1.141.2",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"i18next": "^25.8.0",
		"i18next-browser-languagedetector": "^8.2.0",
		"lucide-react": "^0.544.0",
		"next-themes": "^0.4.6",
		"react": "^19.2.3",
		"react-dom": "^19.2.3",
		"react-hook-form": "^7.68.0",
		"react-i18next": "^16.5.3",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.4.0",
		"tailwindcss": "^4.1.18",
		"usehooks-ts": "^3.1.1",
		"pumpkin-tree-contracts": "workspace:*"
	},
	"devDependencies": {
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^5.1.2",
		"@vitest/ui": "^4.0.18",
		"autoprefixer": "^10.4.22",
		"eslint-plugin-react-hooks": "^5.2.0",
		"eslint-plugin-react-refresh": "^0.4.24",
		"globals": "^16.5.0",
		"jsdom": "^27.4.0",
		"shadcn": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"vite": "^7.2.7",
		"vite-tsconfig-paths": "^5.1.4",
		"vitest": "^4.0.18"
	}
}
