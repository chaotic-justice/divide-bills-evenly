{
	"compilerOptions": {
		"tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
		"incremental": true,
		"composite": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./src/*"],
			"pumpkin-tree-contracts": ["../../packages/contracts/src"],
			"pumpkin-tree-contracts/*": ["../../packages/contracts/src/*"]
		},
		"types": ["./worker-configuration.d.ts", "node", "vite/client"]
	},
	"extends": "../../packages/typescript-config/vite-app.json",
	"references": [
		{
			"path": "../../packages/contracts/tsconfig.build.json"
		}
	],
	"include": ["src"]
}
